---
import LegalLayout from '../layouts/LegalLayout.astro';
import { t } from '../i18n/ui';

// Legal markdown is synced from PRIVACY.md at the repo root before build.
// See scripts/sync-legal.mjs.
const { Content } = await import('../content/legal/privacy.en.md');

const locale = 'en' as const;
---

<LegalLayout locale={locale} title={t(locale, 'legal.privacy.title')} pathname="/privacy">
  <Content />
</LegalLayout>
