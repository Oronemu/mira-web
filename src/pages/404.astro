---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n/ui';
import { localizedPath } from '../i18n/utils';

const locale = 'en' as const;
---

<BaseLayout locale={locale} title="404 — Mira" pathname="/">
  <section class="px-4 py-20 sm:px-6">
    <div class="mx-auto max-w-xl text-center">
      <div class="glass px-8 py-16">
        <p class="eyebrow">404</p>
        <h1
          class="mt-4 font-serif text-[clamp(2rem,5vw,3rem)] font-medium leading-tight"
          style="font-variation-settings: 'opsz' 144, 'wght' 500, 'SOFT' 80;"
        >
          {t(locale, '404.title')}
        </h1>
        <p class="mt-5 text-ink-soft">{t(locale, '404.body')}</p>
        <a href={localizedPath(locale, '/')} class="btn btn-primary mt-8">
          {t(locale, '404.cta')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
