---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import type { Locale } from '../consts';
import { SITE } from '../consts';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MoodOrbs from '../components/MoodOrbs.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

interface Props {
  locale: Locale;
  title: string;
  description?: string;
  /** Pathname stripped of locale prefix, used by LangSwitch + alternate links. */
  pathname?: string;
  ogImage?: string;
}

const {
  locale,
  title,
  description = SITE.description[locale],
  pathname = '/',
  ogImage = '/og-image.svg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const altPath =
  locale === 'en' ? `/ru${pathname === '/' ? '' : pathname}` : pathname;
const altUrl = new URL(altPath, SITE.url).toString();
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0F0F12" />
    <meta name="color-scheme" content="dark light" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={locale === 'en' ? 'ru' : 'en'} href={altUrl} />
    <link rel="alternate" hreflang="x-default" href={SITE.url} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts: Fraunces (variable serif) + Inter (sans). bunny.net = no Google tracking. -->
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=fraunces:300,400,500,600,700,300i,400i,500i,600i,700i&family=inter:400,500,600,700&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : 'ru_RU'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={new URL(ogImage, SITE.url).toString()} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Default = dark; only flip to light if the user explicitly chose it.
         Inline + `is:inline` so we apply the class before first paint (no flash).
         Also re-applied on `astro:after-swap` because View Transitions reset
         the `<html>` class (and `<meta name="theme-color">`) to the server-
         rendered defaults on every soft navigation — without this hook the
         user's choice would be lost the moment they switch language. -->
    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var isLight = localStorage.getItem('theme') === 'light';
            document.documentElement.classList.toggle('dark', !isLight);
            var meta = document.querySelector('meta[name="theme-color"]');
            if (meta) meta.setAttribute('content', isLight ? '#FAF7F2' : '#0F0F12');
          } catch (_) {
            document.documentElement.classList.add('dark');
          }
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <ViewTransitions />
  </head>
  <body class="relative font-sans text-ink antialiased dark:text-cream">
    <MoodOrbs />
    <Header locale={locale} pathname={pathname} />
    <main id="main" class="relative z-10 pt-24">
      <slot />
    </main>
    <Footer locale={locale} pathname={pathname} />
    <ScrollReveal />
  </body>
</html>
