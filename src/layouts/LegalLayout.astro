---
import BaseLayout from './BaseLayout.astro';
import type { Locale } from '../consts';
import { localizedPath } from '../i18n/utils';
import { t } from '../i18n/ui';

interface Props {
  locale: Locale;
  title: string;
  pathname: string;
}

const { locale, title, pathname } = Astro.props;
---

<BaseLayout locale={locale} title={`${title} — Mira`} pathname={pathname}>
  <article class="mx-auto max-w-3xl px-4 pb-24 pt-8 sm:px-6">
    <a
      href={localizedPath(locale, '/')}
      class="mb-8 inline-flex items-center gap-2 text-sm text-ink-muted transition-colors hover:text-ink dark:hover:text-cream"
    >
      <span aria-hidden="true">←</span>
      {t(locale, 'legal.back')}
    </a>
    <div class="glass px-6 py-10 sm:px-10 sm:py-14">
      <div class="prose-legal">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
