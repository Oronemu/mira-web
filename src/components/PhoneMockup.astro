---
import type { Locale } from '../consts';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

// Sample journal entries shown inside the mockup. Kept short, evocative.
const entries =
  locale === 'ru'
    ? [
        { date: 'ВТ · 5 МАЯ', mood: '🌤', title: 'После прогулки', body: 'Воздух пах дождём. Кажется, я перестал спешить.' },
        { date: 'ПН · 4 МАЯ', mood: '🌙', title: 'Перед сном', body: 'Сегодня сделал немного. И этого достаточно.' },
        { date: 'ВС · 3 МАЯ', mood: '☕', title: 'Утренний кофе', body: 'Тишина в кухне. Книга открыта на середине.' },
      ]
    : [
        { date: 'TUE · MAY 5', mood: '🌤', title: 'After the walk', body: 'The air smelled like rain. I think I stopped rushing.' },
        { date: 'MON · MAY 4', mood: '🌙', title: 'Before sleep', body: 'I did very little today. And it was enough.' },
        { date: 'SUN · MAY 3', mood: '☕', title: 'Morning coffee', body: 'Quiet kitchen. The book open at the middle.' },
      ];

const askLabel = locale === 'ru' ? 'Спросите Mira' : 'Ask Mira';
const askPrompt =
  locale === 'ru'
    ? 'Что меня успокаивало в апреле?'
    : 'What was calming me in April?';
---

<div class="relative mx-auto w-full max-w-[340px] sm:max-w-[380px]">
  <!-- Soft halo glow behind the phone -->
  <div
    class="absolute -inset-10 -z-10 rounded-full blur-3xl"
    style="background: radial-gradient(circle at 50% 40%, rgba(217,179,108,0.35), transparent 60%);"
    aria-hidden="true"
  ></div>

  <!-- Phone frame: a CSS-only iPhone silhouette with Dynamic Island -->
  <div
    class="relative aspect-[9/19.5] overflow-hidden rounded-[3rem] border border-black/10 bg-cream-deep p-2 shadow-[0_50px_100px_-20px_rgba(28,27,31,0.4),0_8px_24px_-8px_rgba(28,27,31,0.2)] animate-floaty dark:border-white/10 dark:bg-night-surface"
    style="background: linear-gradient(160deg, #f7f1e6 0%, #ebe2d2 100%);"
  >
    <!-- Bezel inner glow -->
    <div class="absolute inset-1 rounded-[2.7rem] ring-1 ring-inset ring-black/5 dark:ring-white/5" aria-hidden="true"></div>

    <!-- Screen -->
    <div class="relative h-full w-full overflow-hidden rounded-[2.5rem] bg-cream dark:bg-night">
      <!-- Mood gradient header -->
      <div
        class="absolute inset-x-0 top-0 h-44"
        style="background: radial-gradient(ellipse at 30% 0%, rgba(217,183,176,0.6), transparent 60%), radial-gradient(ellipse at 100% 30%, rgba(164,181,162,0.45), transparent 60%);"
        aria-hidden="true"
      ></div>

      <!-- Dynamic Island -->
      <div class="absolute left-1/2 top-3 z-20 h-7 w-24 -translate-x-1/2 rounded-full bg-black" aria-hidden="true"></div>

      <!-- Status bar -->
      <div class="relative z-10 flex items-center justify-between px-7 pt-3 text-[10px] font-medium text-ink dark:text-cream">
        <span>9:41</span>
        <span class="flex items-center gap-1 opacity-70">
          <svg viewBox="0 0 16 10" class="h-2.5 w-4 fill-current"><path d="M1 5h2v4H1zm4-2h2v6H5zm4-2h2v8H9zm4-2h2v10h-2z"/></svg>
          <svg viewBox="0 0 16 10" class="h-2.5 w-4 fill-current"><path d="M0 5a8 8 0 0 1 16 0h-2a6 6 0 0 0-12 0H0Zm4 0a4 4 0 0 1 8 0h-2a2 2 0 0 0-4 0H4Zm3 0a1 1 0 0 1 2 0H7Z"/></svg>
          <svg viewBox="0 0 24 10" class="h-2.5 w-5 fill-current"><rect x="0.5" y="0.5" width="20" height="9" rx="2" stroke="currentColor" fill="none"/><rect x="2" y="2" width="14" height="6" rx="1"/><rect x="21" y="3" width="2" height="4" rx="0.5"/></svg>
        </span>
      </div>

      <!-- Title -->
      <div class="relative z-10 px-7 pt-8">
        <p class="text-[11px] font-medium uppercase tracking-[0.18em] text-ink-muted">
          {locale === 'ru' ? 'Май 2026' : 'May 2026'}
        </p>
        <h3 class="mt-1 font-serif text-[28px] font-medium leading-tight tracking-tight text-ink dark:text-cream">
          {locale === 'ru' ? 'Сегодня' : 'Today'}
        </h3>
      </div>

      <!-- Mood ring of last 7 days -->
      <div class="relative z-10 mt-5 flex justify-between px-7">
        {[
          { c: '#D9B7B0' },
          { c: '#A4B5A2' },
          { c: '#D9B36C' },
          { c: '#D9B7B0' },
          { c: '#B98D85' },
          { c: '#A4B5A2' },
          { c: '#D9B36C' },
        ].map((d, i) => (
          <span
            class="h-3 w-3 rounded-full ring-1 ring-white/60"
            style={`background:${d.c}; opacity:${0.5 + i * 0.07};`}
            aria-hidden="true"
          ></span>
        ))}
      </div>

      <!-- Entries list -->
      <div class="relative z-10 mt-6 space-y-2.5 px-4">
        {entries.map((e, i) => (
          <div
            class="rounded-2xl border border-black/5 bg-white/70 px-4 py-3 backdrop-blur-md dark:border-white/5 dark:bg-white/5"
            style={`transform: translateY(${i * 0}px);`}
          >
            <div class="flex items-center justify-between text-[10px] uppercase tracking-[0.14em] text-ink-muted">
              <span>{e.date}</span>
              <span class="text-base leading-none">{e.mood}</span>
            </div>
            <p class="mt-1 font-serif text-[15px] font-medium leading-snug text-ink dark:text-cream">
              {e.title}
            </p>
            <p class="mt-1 line-clamp-2 text-[12px] leading-snug text-ink-soft">
              {e.body}
            </p>
          </div>
        ))}
      </div>

      <!-- Ask Mira composer pinned to bottom -->
      <div class="absolute inset-x-3 bottom-3 z-10">
        <div
          class="flex items-center gap-2 rounded-full border border-black/5 bg-white/80 px-3 py-2 shadow-md backdrop-blur-xl dark:border-white/10 dark:bg-night-surface/80"
        >
          <span
            class="grid h-7 w-7 shrink-0 place-items-center rounded-full font-serif text-sm italic font-medium"
            style="background: radial-gradient(circle at 30% 30%, #FBE7DD, #D9B7B0 55%, #7A8E78);"
          >m</span>
          <div class="min-w-0 flex-1">
            <p class="text-[9px] font-medium uppercase tracking-[0.16em] text-ink-muted">{askLabel}</p>
            <p class="truncate text-[12px] text-ink dark:text-cream">{askPrompt}</p>
          </div>
          <span
            class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-ink text-cream dark:bg-cream dark:text-ink"
            aria-hidden="true"
          >↑</span>
        </div>
      </div>
    </div>
  </div>
</div>
