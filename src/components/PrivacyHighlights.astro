---
import type { Locale } from '../consts';
import { t } from '../i18n/ui';

interface Props { locale: Locale }
const { locale } = Astro.props;

const items = [
  {
    titleKey: 'privacy.local.title',
    bodyKey: 'privacy.local.body',
    icon: `<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/><circle cx="12" cy="16" r="1.5" fill="currentColor"/>`,
  },
  {
    titleKey: 'privacy.telemetry.title',
    bodyKey: 'privacy.telemetry.body',
    icon: `<path d="M12 3v18M5 8l7 4 7-4M5 16l7-4 7 4"/>`,
  },
  {
    titleKey: 'privacy.encrypted.title',
    bodyKey: 'privacy.encrypted.body',
    icon: `<path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4Z"/><path d="m9 12 2 2 4-4"/>`,
  },
] as const;
---

<section id="privacy" class="relative px-4 py-28 sm:px-6">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="eyebrow">{t(locale, 'privacy.eyebrow')}</p>
      <h2
        class="mt-4 font-serif text-[clamp(2rem,4.5vw,3.4rem)] font-medium leading-[1.05] tracking-tight"
        style="font-variation-settings: 'opsz' 144, 'wght' 500, 'SOFT' 80;"
      >
        {t(locale, 'privacy.title')}
      </h2>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-3">
      {items.map((item, i) => (
        <article
          class="glass reveal flex flex-col p-8"
          data-delay={String(i + 1)}
        >
          <div
            class="grid h-14 w-14 place-items-center rounded-2xl text-ink"
            style="background: linear-gradient(140deg, rgba(217,179,108,0.25), rgba(164,181,162,0.25));"
          >
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon}></svg>
          </div>
          <h3
            class="mt-6 font-serif text-2xl font-medium leading-snug"
            style="font-variation-settings: 'opsz' 32, 'wght' 500, 'SOFT' 60;"
          >
            {t(locale, item.titleKey)}
          </h3>
          <p class="mt-3 text-[15px] leading-relaxed text-ink-soft">
            {t(locale, item.bodyKey)}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
