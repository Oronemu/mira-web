---
import type { Locale } from '../consts';
import { t } from '../i18n/ui';

interface Props { locale: Locale }
const { locale } = Astro.props;
---

<section id="ai" class="relative px-4 py-28 sm:px-6">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="eyebrow">{t(locale, 'ai.eyebrow')}</p>
      <h2
        class="mt-4 font-serif text-[clamp(2rem,4.5vw,3.4rem)] font-medium leading-[1.05] tracking-tight"
        style="font-variation-settings: 'opsz' 144, 'wght' 500, 'SOFT' 80;"
      >
        {t(locale, 'ai.title')}
      </h2>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2">
      <article class="glass reveal relative overflow-hidden p-8">
        <span
          class="absolute -right-12 -top-12 h-44 w-44 rounded-full opacity-50 blur-2xl"
          style="background: #A4B5A2;"
          aria-hidden="true"
        ></span>
        <span class="eyebrow text-sage-deep">{t(locale, 'ai.local.label')}</span>
        <h3
          class="mt-3 font-serif text-2xl font-medium leading-snug"
          style="font-variation-settings: 'opsz' 32, 'wght' 500, 'SOFT' 60;"
        >
          {t(locale, 'ai.local.title')}
        </h3>
        <p class="mt-3 text-[15px] leading-relaxed text-ink-soft">
          {t(locale, 'ai.local.body')}
        </p>
        <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-black/5 bg-white/50 px-3 py-1 text-xs text-ink-muted backdrop-blur-md dark:border-white/10 dark:bg-white/5">
          <span class="h-2 w-2 animate-pulse rounded-full bg-sage" aria-hidden="true"></span>
          {locale === 'ru' ? 'Без сети · Без лимитов' : 'No network · No limits'}
        </div>
      </article>

      <article class="glass reveal relative overflow-hidden p-8" data-delay="2">
        <span
          class="absolute -right-12 -top-12 h-44 w-44 rounded-full opacity-50 blur-2xl"
          style="background: #D9B36C;"
          aria-hidden="true"
        ></span>
        <span class="eyebrow text-ochre-deep">{t(locale, 'ai.cloud.label')}</span>
        <h3
          class="mt-3 font-serif text-2xl font-medium leading-snug"
          style="font-variation-settings: 'opsz' 32, 'wght' 500, 'SOFT' 60;"
        >
          {t(locale, 'ai.cloud.title')}
        </h3>
        <p class="mt-3 text-[15px] leading-relaxed text-ink-soft">
          {t(locale, 'ai.cloud.body')}
        </p>
        <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-black/5 bg-white/50 px-3 py-1 text-xs text-ink-muted backdrop-blur-md dark:border-white/10 dark:bg-white/5">
          <span class="h-2 w-2 animate-pulse rounded-full bg-ochre" aria-hidden="true"></span>
          {locale === 'ru' ? 'На базе Claude' : 'Powered by Claude'}
        </div>
      </article>
    </div>
  </div>
</section>
