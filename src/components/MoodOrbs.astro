---
// Three slow-drifting mood-colored orbs behind the glass surfaces.
// Pure CSS animation, GPU-friendly, respects prefers-reduced-motion.
---

<div class="mood-orbs" aria-hidden="true">
  <div class="mood-orb animate-drift" style="top: -10%; left: -10%; width: 50vw; height: 50vw; background: #d9b7b0;"></div>
  <div class="mood-orb animate-drift-slow" style="top: 30%; right: -15%; width: 55vw; height: 55vw; background: #a4b5a2; animation-delay: -8s;"></div>
  <div class="mood-orb animate-drift" style="bottom: -20%; left: 20%; width: 60vw; height: 60vw; background: #d9b36c; opacity: 0.4; animation-delay: -16s;"></div>
</div>
<div class="grain" aria-hidden="true"></div>
