---
import type { Locale } from '../consts';
import { t } from '../i18n/ui';

interface Props { locale: Locale }
const { locale } = Astro.props;

// Inline SVG icons keep us free of any icon-library dependency.
// Each path is a single line at ~24px, stroke-based, in step with iOS visual weight.
const features = [
  {
    titleKey: 'features.write.title',
    bodyKey: 'features.write.body',
    icon: `<path d="M4 19h16M5 17l8-12a2 2 0 0 1 3-1l1 1a2 2 0 0 1 0 3L9 16l-4 1Z"/>`,
    accent: '#D9B7B0',
  },
  {
    titleKey: 'features.local.title',
    bodyKey: 'features.local.body',
    icon: `<path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/><circle cx="12" cy="12" r="4"/>`,
    accent: '#A4B5A2',
  },
  {
    titleKey: 'features.ask.title',
    bodyKey: 'features.ask.body',
    icon: `<path d="M21 12a8 8 0 1 1-3-6.2L21 5l-.8 3a8 8 0 0 1 .8 4ZM9 11h6M9 14h4"/>`,
    accent: '#D9B36C',
  },
  {
    titleKey: 'features.calendar.title',
    bodyKey: 'features.calendar.body',
    icon: `<rect x="4" y="6" width="16" height="14" rx="2"/><path d="M4 10h16M9 3v4M15 3v4"/><circle cx="12" cy="14" r="1.5" fill="currentColor"/>`,
    accent: '#B98D85',
  },
  {
    titleKey: 'features.sync.title',
    bodyKey: 'features.sync.body',
    icon: `<path d="M7 16a5 5 0 1 1 1.5-9.8A6 6 0 0 1 20 11h.5a3.5 3.5 0 0 1 0 7H17M12 13v6m0 0-2-2m2 2 2-2"/>`,
    accent: '#7A8E78',
  },
  {
    titleKey: 'features.lock.title',
    bodyKey: 'features.lock.body',
    icon: `<rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4M12 15v3"/>`,
    accent: '#B5904B',
  },
] as const;
---

<section id="features" class="relative px-4 py-28 sm:px-6">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="eyebrow">{t(locale, 'features.eyebrow')}</p>
      <h2
        class="mt-4 font-serif text-[clamp(2rem,4.5vw,3.4rem)] font-medium leading-[1.05] tracking-tight"
        style="font-variation-settings: 'opsz' 144, 'wght' 500, 'SOFT' 80;"
      >
        {t(locale, 'features.title')}
      </h2>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f, i) => (
        <article
          class="glass glass-shine reveal group relative p-7 transition-transform duration-700 ease-quiet hover:-translate-y-1"
          data-delay={String(Math.min(i + 1, 5))}
        >
          <span
            class="absolute right-6 top-6 h-2 w-2 rounded-full opacity-70 transition-opacity duration-500 group-hover:opacity-100"
            style={`background:${f.accent}; box-shadow: 0 0 20px ${f.accent};`}
            aria-hidden="true"
          ></span>
          <div
            class="grid h-12 w-12 place-items-center rounded-2xl"
            style={`background: ${f.accent}26; color: ${f.accent};`}
          >
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon}></svg>
          </div>
          <h3
            class="mt-5 font-serif text-xl font-medium leading-snug text-ink dark:text-cream"
            style="font-variation-settings: 'opsz' 24, 'wght' 500, 'SOFT' 60;"
          >
            {t(locale, f.titleKey)}
          </h3>
          <p class="mt-2 text-[15px] leading-relaxed text-ink-soft">
            {t(locale, f.bodyKey)}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
